PORT=8080
NODE_ENV=production

# MongoDB Atlas connection string
# Get from: cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net
DB_NAME=jobbuddy

# JWT Secret — MUST be 64-char random hex in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_64_chars

# Gemini AI API Key
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# ── ONLY needed for split deploy (Vercel frontend + Render backend) ──
# Leave blank/unset for full-stack single-service deployment (Option 2)
# ALLOWED_ORIGINS=https://your-app.vercel.app
